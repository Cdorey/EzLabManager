<UserControl x:Class="EzLabManager.Views.InventorySummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部搜索区 -->
        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="库存关键词："
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />

            <TextBox Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding InventorySearchKeyword, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="搜索"
                    Command="{Binding SearchInventoryCommand}" />

            <Button Grid.Column="3"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="刷新"
                    Command="{Binding RefreshCommand}" />

            <CheckBox Grid.Column="4"
                      Margin="16,0,0,0"
                      VerticalAlignment="Center"
                      Content="包含零库存"
                      IsChecked="{Binding IncludeZeroStock, Mode=TwoWay}" />
        </Grid>

        <!-- 库存汇总区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0"
                      Header="按耗材汇总">
                <DataGrid ItemsSource="{Binding ItemSummaries}"
                          SelectedItem="{Binding SelectedItemSummary, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="类目"
                                            Binding="{Binding CategoryName}"
                                            Width="*" />

                        <DataGridTextColumn Header="型号 / 规格"
                                            Binding="{Binding ModelName}"
                                            Width="*" />

                        <DataGridTextColumn Header="入库"
                                            Binding="{Binding InboundQuantity}"
                                            Width="70" />

                        <DataGridTextColumn Header="出库"
                                            Binding="{Binding OutboundQuantity}"
                                            Width="70" />

                        <DataGridTextColumn Header="剩余"
                                            Binding="{Binding RemainingQuantity}"
                                            Width="70" />

                        <DataGridTextColumn Header="批次"
                                            Binding="{Binding AvailableBatchCount}"
                                            Width="70" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Column="2"
                      Header="按批次明细">
                <DataGrid ItemsSource="{Binding BatchSummaries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="耗材"
                                            Binding="{Binding ConsumableDisplayName}"
                                            Width="*" />

                        <DataGridTextColumn Header="批号"
                                            Binding="{Binding BatchNumber}"
                                            Width="110" />

                        <DataGridTextColumn Header="效期"
                                            Binding="{Binding ExpirationDate, StringFormat=yyyy-MM-dd}"
                                            Width="95" />

                        <DataGridTextColumn Header="入库日期"
                                            Binding="{Binding InboundDate, StringFormat=yyyy-MM-dd}"
                                            Width="95" />

                        <DataGridTextColumn Header="入库"
                                            Binding="{Binding InboundQuantity}"
                                            Width="60" />

                        <DataGridTextColumn Header="已出"
                                            Binding="{Binding OutboundQuantity}"
                                            Width="60" />

                        <DataGridTextColumn Header="剩余"
                                            Binding="{Binding RemainingQuantity}"
                                            Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- 耗材基础信息维护 -->
        <GroupBox Grid.Row="3"
                  Header="耗材基础信息维护">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="当前ID："
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <TextBlock Grid.Column="1"
                           Text="{Binding EditingConsumableItemId, TargetNullValue=新建}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <TextBlock Grid.Column="2"
                           Text="类目："
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <TextBox Grid.Column="3"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Margin="0,0,16,0"
                         Text="{Binding EditingConsumableCategoryName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="4"
                           Text="型号 / 规格："
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <TextBox Grid.Column="5"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Margin="0,0,16,0"
                         Text="{Binding EditingConsumableModelName, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Column="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="80"
                            Height="30"
                            Content="空白新建"
                            Command="{Binding PrepareBlankConsumableItemCommand}" />

                    <Button Width="120"
                            Height="30"
                            Margin="8,0,0,0"
                            Content="复制新规格"
                            Command="{Binding PrepareCopiedConsumableItemCommand}" />

                    <Button Width="80"
                            Height="30"
                            Margin="8,0,0,0"
                            Content="保存"
                            Command="{Binding SaveConsumableItemCommand}" />

                    <Button Width="80"
                            Height="30"
                            Margin="8,0,0,0"
                            Content="删除"
                            Command="{Binding DeleteConsumableItemCommand}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 状态栏 -->
        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Padding="8"
                BorderThickness="1"
                BorderBrush="#DDD">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</UserControl>