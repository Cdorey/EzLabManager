<Window x:Class="EzLabManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EzLabManager.Views"
        Title="EzLabManager"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <TabControl>
            <TabItem Header="库存汇总">
                <views:InventorySummaryView DataContext="{Binding InventorySummaryViewModel}" />
            </TabItem>

            <TabItem Header="检验师管理">
                <views:LabTechnicianView DataContext="{Binding LabTechnicianViewModel}" />
            </TabItem>

            <TabItem Header="入库管理">
                <views:InboundRecordView DataContext="{Binding InboundRecordViewModel}" />
            </TabItem>

            <TabItem Header="出库管理">
                <views:OutboundRecordView DataContext="{Binding OutboundRecordViewModel}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>