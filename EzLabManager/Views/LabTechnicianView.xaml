<UserControl x:Class="EzLabManager.Views.LabTechnicianView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部搜索区 -->
        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="关键词："
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />

            <TextBox Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding LabTechnicianSearchKeyword, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="搜索"
                    Command="{Binding SearchLabTechniciansCommand}" />

            <CheckBox Grid.Column="3"
                      Margin="16,0,0,0"
                      VerticalAlignment="Center"
                      Content="包含无效人员"
                      IsChecked="{Binding IncludeInactiveLabTechnicians, Mode=TwoWay}" />
        </Grid>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧列表 -->
            <GroupBox Grid.Column="0"
                      Header="检验师列表">
                <DataGrid ItemsSource="{Binding LabTechnicians}"
                          SelectedItem="{Binding SelectedLabTechnician, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="70" />

                        <DataGridTextColumn Header="姓名"
                                            Binding="{Binding Name}"
                                            Width="*" />

                        <DataGridTextColumn Header="工号"
                                            Binding="{Binding EmployeeNumber}"
                                            Width="*" />

                        <DataGridCheckBoxColumn Header="有效"
                                                Binding="{Binding IsActive}"
                                                Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- 右侧编辑区 -->
            <GroupBox Grid.Column="2"
                      Header="编辑检验师">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="当前ID："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding EditingLabTechnicianId, TargetNullValue=新建}"
                               VerticalAlignment="Center"
                               Margin="0,0,0,10" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="姓名："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10"
                             Text="{Binding EditingLabTechnicianName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="工号："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10"
                             Text="{Binding EditingLabTechnicianEmployeeNumber, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="有效："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <CheckBox Grid.Row="3"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Margin="0,0,0,10"
                              IsChecked="{Binding EditingLabTechnicianIsActive, Mode=TwoWay}" />

                    <StackPanel Grid.Row="5"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Width="80"
                                Height="30"
                                Content="新建"
                                Command="{Binding NewLabTechnicianCommand}" />

                        <Button Width="80"
                                Height="30"
                                Margin="8,0,0,0"
                                Content="保存"
                                Command="{Binding SaveLabTechnicianCommand}" />

                        <Button Width="90"
                                Height="30"
                                Margin="8,0,0,0"
                                Content="删除/停用"
                                Command="{Binding DeleteLabTechnicianCommand}" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 检验师页面状态栏 -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="8"
                BorderThickness="1"
                BorderBrush="#DDD">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</UserControl>