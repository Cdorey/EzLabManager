<UserControl x:Class="EzLabManager.Views.OutboundRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部搜索区 -->
        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="库存关键词："
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />

            <TextBox Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding InventoryBatchSearchKeyword, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="搜索"
                    Command="{Binding SearchInventoryBatchesCommand}" />

            <Button Grid.Column="3"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="刷新"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.7*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.0*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：可出库库存批次 -->
            <GroupBox Grid.Column="0"
                      Header="可出库库存批次">
                <DataGrid ItemsSource="{Binding AvailableBatches}"
                          SelectedItem="{Binding SelectedInventoryBatch, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="耗材"
                                            Binding="{Binding ConsumableDisplayName}"
                                            Width="*" />

                        <DataGridTextColumn Header="批号"
                                            Binding="{Binding BatchNumber}"
                                            Width="100" />

                        <DataGridTextColumn Header="效期"
                                            Binding="{Binding ExpirationDate, StringFormat=yyyy-MM-dd}"
                                            Width="90" />

                        <DataGridTextColumn Header="入库"
                                            Binding="{Binding InboundQuantity}"
                                            Width="60" />

                        <DataGridTextColumn Header="已出"
                                            Binding="{Binding OutboundQuantity}"
                                            Width="60" />

                        <DataGridTextColumn Header="剩余"
                                            Binding="{Binding RemainingQuantity}"
                                            Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- 中间：出库表单 -->
            <GroupBox Grid.Column="2"
                      Header="录入出库信息">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="当前耗材："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding SelectedInventoryBatch.ConsumableDisplayName, TargetNullValue=未选择}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="0,0,0,10" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="批号："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding SelectedInventoryBatch.BatchNumber, TargetNullValue=未选择}"
                               VerticalAlignment="Center"
                               Margin="0,0,0,10" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="剩余："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding SelectedInventoryBatch.RemainingQuantity, TargetNullValue=0}"
                               VerticalAlignment="Center"
                               Margin="0,0,0,10" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="出库数量："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10"
                             Text="{Binding OutboundQuantity, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="出账日期："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <DatePicker Grid.Row="4"
                                Grid.Column="1"
                                Height="30"
                                Margin="0,0,0,10"
                                SelectedDate="{Binding OutboundDate, Mode=TwoWay}" />

                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Text="出账人："
                               VerticalAlignment="Top"
                               Margin="0,4,8,10" />

                    <ComboBox Grid.Row="5"
                              Grid.Column="1"
                              Height="30"
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,10"
                              ItemsSource="{Binding ActiveLabTechnicians}"
                              SelectedItem="{Binding SelectedOutboundBy, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}（{1}）">
                                            <Binding Path="Name" />
                                            <Binding Path="EmployeeNumber" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Row="6"
                            Grid.ColumnSpan="2"
                            Height="32"
                            Width="120"
                            HorizontalAlignment="Right"
                            Content="保存出库"
                            Command="{Binding SaveOutboundRecordCommand}" />
                </Grid>
            </GroupBox>

            <!-- 右侧：最近出库记录 -->
            <GroupBox Grid.Column="4"
                      Header="最近出库记录">
                <DataGrid ItemsSource="{Binding RecentOutboundRecords}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期"
                                            Binding="{Binding OutboundDate, StringFormat=yyyy-MM-dd}"
                                            Width="90" />

                        <DataGridTextColumn Header="耗材"
                                            Binding="{Binding ConsumableDisplayName}"
                                            Width="*" />

                        <DataGridTextColumn Header="批号"
                                            Binding="{Binding BatchNumber}"
                                            Width="100" />

                        <DataGridTextColumn Header="数量"
                                            Binding="{Binding Quantity}"
                                            Width="70" />

                        <DataGridTextColumn Header="出账人"
                                            Binding="{Binding OutboundByName}"
                                            Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="8"
                BorderThickness="1"
                BorderBrush="#DDD">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</UserControl>