<UserControl x:Class="EzLabManager.Views.InboundRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部操作区 -->
        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="耗材关键词："
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />

            <TextBox Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding ConsumableSearchKeyword, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="搜索"
                    Command="{Binding SearchConsumableItemsCommand}" />

            <Button Grid.Column="3"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="刷新"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：选择已有耗材 -->
            <GroupBox Grid.Column="0"
                      Header="选择入库耗材">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="请选择一种已有耗材："
                               Margin="0,0,0,8" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ConsumableItems}"
                              SelectedItem="{Binding SelectedConsumableItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="类目"
                                                Binding="{Binding CategoryName}"
                                                Width="*" />

                            <DataGridTextColumn Header="型号 / 规格"
                                                Binding="{Binding ModelName}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <!-- 中间：新建耗材与入库表单 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0"
                          Header="新建耗材">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <Button Width="100"
                                    Height="30"
                                    Content="空白新建"
                                    Command="{Binding PrepareBlankConsumableItemCommand}" />

                            <Button Width="130"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Content="复制当前新规格"
                                    Command="{Binding PrepareCopiedConsumableItemCommand}" />
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="类目："
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,10" />

                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"
                                 Text="{Binding NewConsumableCategoryName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="型号 / 规格："
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,10" />

                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"
                                 Text="{Binding NewConsumableModelName, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Row="3"
                                Grid.ColumnSpan="2"
                                Height="30"
                                HorizontalAlignment="Right"
                                Width="120"
                                Content="保存并选中"
                                Command="{Binding CreateConsumableItemCommand}" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2"
                          Header="录入入库信息">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="当前耗材："
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,10" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="未选择" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedConsumableItem}" Value="{x:Null}">
                                            <Setter Property="Text" Value="未选择" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} - {1}">
                                    <Binding Path="SelectedConsumableItem.CategoryName" />
                                    <Binding Path="SelectedConsumableItem.ModelName" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="批号："
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,10" />

                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"
                                 Text="{Binding InboundBatchNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="效期："
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,10" />

                        <DatePicker Grid.Row="2"
                                    Grid.Column="1"
                                    Height="30"
                                    Margin="0,0,0,10"
                                    SelectedDate="{Binding InboundExpirationDate, Mode=TwoWay}" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="数量："
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,10" />

                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"
                                 Text="{Binding InboundQuantity, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="入账日期："
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,10" />

                        <DatePicker Grid.Row="4"
                                    Grid.Column="1"
                                    Height="30"
                                    Margin="0,0,0,10"
                                    SelectedDate="{Binding InboundDate, Mode=TwoWay}" />

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Text="入账人："
                                   VerticalAlignment="Top"
                                   Margin="0,4,8,10" />

                        <ComboBox Grid.Row="5"
                                  Grid.Column="1"
                                  Height="30"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,0,10"
                                  ItemsSource="{Binding ActiveLabTechnicians}"
                                  SelectedItem="{Binding SelectedInboundBy, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}（{1}）">
                                                <Binding Path="Name" />
                                                <Binding Path="EmployeeNumber" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Row="6"
                                Grid.ColumnSpan="2"
                                Height="32"
                                Width="120"
                                HorizontalAlignment="Right"
                                Content="保存入库"
                                Command="{Binding SaveInboundRecordCommand}" />
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- 右侧：最近入库记录 -->
            <GroupBox Grid.Column="4"
                      Header="最近入库记录">
                <DataGrid ItemsSource="{Binding RecentInboundRecords}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期"
                                            Binding="{Binding InboundDate, StringFormat=yyyy-MM-dd}"
                                            Width="90" />

                        <DataGridTextColumn Header="耗材"
                                            Binding="{Binding ConsumableDisplayName}"
                                            Width="*" />

                        <DataGridTextColumn Header="批号"
                                            Binding="{Binding BatchNumber}"
                                            Width="100" />

                        <DataGridTextColumn Header="数量"
                                            Binding="{Binding Quantity}"
                                            Width="70" />

                        <DataGridTextColumn Header="入账人"
                                            Binding="{Binding InboundByName}"
                                            Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="8"
                BorderThickness="1"
                BorderBrush="#DDD">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</UserControl>