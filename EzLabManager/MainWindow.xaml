<Window x:Class="EzLabManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EzLabManager"
        Height="560"
        Width="920"
        MinHeight="480"
        MinWidth="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部搜索区 -->
        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="关键词："
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />

            <TextBox Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="搜索"
                    Command="{Binding SearchCommand}" />
        </Grid>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧列表 -->
            <GroupBox Grid.Column="0"
                      Header="耗材基础信息">
                <DataGrid ItemsSource="{Binding ConsumableItems}"
                          SelectedItem="{Binding SelectedConsumableItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="70" />

                        <DataGridTextColumn Header="类目"
                                            Binding="{Binding CategoryName}"
                                            Width="*" />

                        <DataGridTextColumn Header="型号 / 规格"
                                            Binding="{Binding ModelName}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- 右侧编辑区 -->
            <GroupBox Grid.Column="2"
                      Header="编辑耗材">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="当前ID："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding EditingId, TargetNullValue=新建}"
                               VerticalAlignment="Center"
                               Margin="0,0,0,10" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="耗材类目："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10"
                             Text="{Binding EditingCategoryName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="型号 / 规格："
                               VerticalAlignment="Center"
                               Margin="0,0,8,10" />

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10"
                             Text="{Binding EditingModelName, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Grid.Row="4"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Width="80"
                                Height="30"
                                Content="新建"
                                Command="{Binding NewCommand}" />

                        <Button Width="80"
                                Height="30"
                                Margin="8,0,0,0"
                                Content="保存"
                                Command="{Binding SaveCommand}" />

                        <Button Width="80"
                                Height="30"
                                Margin="8,0,0,0"
                                Content="删除"
                                Command="{Binding DeleteCommand}" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="8"
                BorderThickness="1"
                BorderBrush="#DDD">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</Window>